# Telegram
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890
TELETHON_SESSION=                        # StringSession (generate via: uv run python scripts/generate_session.py)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF        # Bot from @BotFather
TELEGRAM_OWNER_ID=368222740              # Your Telegram user ID

# AI — configurable provider
AI_PROVIDER=openrouter                   # gemini | openrouter | groq
AI_MODEL=openrouter/free                 # model ID for chosen provider
AI_FALLBACK_PROVIDER=groq
AI_FALLBACK_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://sift:localdev@localhost:5432/sift

# App
LOG_LEVEL=INFO
DIGEST_HOUR=9
TIMEZONE=Europe/Kyiv
